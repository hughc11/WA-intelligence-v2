"""Build a ten-point West Africa news briefing from public RSS search results."""
from __future__ import annotations
import hashlib, html, json, os, re, sys, time
from collections import Counter
from datetime import datetime, timezone
from email.utils import parsedate_to_datetime
from pathlib import Path
from urllib.parse import quote_plus
import feedparser
import requests

ROOT=Path(__file__).resolve().parents[1]
OUT=ROOT/'data'/'briefing.json'
ARCHIVE=ROOT/'data'/'archive'
COUNTRIES=['Benin','Burkina Faso','Cabo Verde','Cape Verde','Côte d’Ivoire','Ivory Coast','Gambia','Ghana','Guinea','Guinea-Bissau','Liberia','Mali','Mauritania','Niger','Nigeria','Senegal','Sierra Leone','Togo']
THEMES=['ECOWAS West Africa politics economy security','West Africa business investment trade','Sahel security diplomacy','West Africa climate health society']
CATEGORY_WORDS={
 'Security':['attack','military','security','insurgent','terror','coup','army','conflict','kidnap','jihad'],
 'Economy':['economy','inflation','trade','investment','bank','currency','debt','oil','mining','business','gdp'],
 'Climate':['climate','flood','drought','weather','environment','energy','rainfall'],
 'Society':['health','education','protest','rights','migration','culture','community','election violence'],
 'Politics':['president','government','minister','parliament','election','diplomacy','ecowas','policy','court']}
SIGNIFICANCE=['election','coup','attack','agreement','sanction','president','central bank','inflation','ecowas','military','billion','dead','killed','launch','reform']

def clean(text:str)->str:
    text=html.unescape(re.sub('<[^>]+>',' ',text or ''))
    return re.sub(r'\s+',' ',text).strip()

def source_from(entry)->str:
    src=getattr(entry,'source',{}) or {}
    return clean(src.get('title','')) or clean(entry.get('author','')) or 'News report'

def category(text:str)->str:
    low=text.lower(); scores={k:sum(w in low for w in words) for k,words in CATEGORY_WORDS.items()}
    return max(scores,key=scores.get) if max(scores.values()) else 'Politics'

def country(text:str)->str:
    low=text.lower()
    for c in COUNTRIES:
        if c.lower() in low:return 'Côte d’Ivoire' if c=='Ivory Coast' else ('Cabo Verde' if c=='Cape Verde' else c)
    return 'Regional'

def normalise_title(title:str)->str:
    title=re.sub(r'\s+-\s+[^-]{2,50}$','',title)
    return re.sub(r'[^a-z0-9 ]','',title.lower())

def published_dt(entry):
    raw=entry.get('published') or entry.get('updated') or ''
    try:return parsedate_to_datetime(raw).astimezone(timezone.utc)
    except Exception:return datetime.now(timezone.utc)

def fetch():
    queries=[f'"{c}" news when:1d' for c in COUNTRIES]+[f'{t} when:1d' for t in THEMES]
    items=[]; seen=set(); headers={'User-Agent':'WestAfricaDailyBrief/1.0 (+educational news reader)'}
    for q in queries:
        url=f'https://news.google.com/rss/search?q={quote_plus(q)}&hl=en-GB&gl=GB&ceid=GB:en'
        try:
            response=requests.get(url,headers=headers,timeout=20); response.raise_for_status(); feed=feedparser.parse(response.content)
            for e in feed.entries[:20]:
                title=clean(e.get('title','')); summary=clean(e.get('summary','')); key=normalise_title(title)
                if len(title)<20 or not key or key in seen:continue
                seen.add(key); text=f'{title} {summary}'
                age=max(0,(datetime.now(timezone.utc)-published_dt(e)).total_seconds()/3600)
                score=max(0,30-age)+sum(7 for w in SIGNIFICANCE if w in text.lower())
                items.append({'title':title,'description':summary,'url':e.get('link',''),'source':source_from(e),'dt':published_dt(e),'category':category(text),'country':country(text),'score':score})
        except Exception as ex: print(f'WARN {q}: {ex}',file=sys.stderr)
        time.sleep(.15)
    return items

def dedupe_and_balance(items):
    items.sort(key=lambda x:x['score'],reverse=True); selected=[]; source_count=Counter(); country_count=Counter()
    for item in items:
        tokens=set(normalise_title(item['title']).split())
        duplicate=any(len(tokens & set(normalise_title(s['title']).split()))/max(1,len(tokens))>.72 for s in selected)
        if duplicate or source_count[item['source']]>=2 or country_count[item['country']]>=2:continue
        selected.append(item);source_count[item['source']]+=1;country_count[item['country']]+=1
        if len(selected)==16:break
    return selected

def fallback_summary(item):
    title=re.sub(r'\s+-\s+[^-]{2,50}$','',item['title']).strip()
    desc=item['description']
    if desc and title.lower() not in desc.lower():
        sentences=re.split(r'(?<=[.!?])\s+',desc)
        detail=next((s for s in sentences if len(s)>45), '')
        if detail:return f'{title}. {detail[:300]}'.strip()
    return title.rstrip('.')+'.'

def ai_summarise(items):
    key=os.getenv('OPENAI_API_KEY')
    if not key:return None
    try:
        from openai import OpenAI
        client=OpenAI(api_key=key)
        evidence='\n'.join(f"[{i}] {x['title']} | {x['description'][:500]} | {x['source']}" for i,x in enumerate(items))
        prompt=f'''You are a cautious West Africa current-affairs editor. Select exactly 10 distinct, consequential developments from the evidence. Do not invent facts. Return strict JSON with key "items", an array of objects: index (integer matching evidence), headline (max 12 words), summary (2 factual sentences, max 70 words), why_it_matters (1 analytical sentence, max 30 words), confidence (one of "Multiple reports", "Source checked", "Developing story"). Balance countries and politics/economy/security/society/climate. Evidence:\n{evidence}'''
        r=client.responses.create(model=os.getenv('OPENAI_MODEL','gpt-5-mini'),input=prompt)
        text=r.output_text.strip().removeprefix('```json').removesuffix('```').strip()
        return json.loads(text)['items']
    except Exception as ex:
        print(f'WARN AI summary failed: {ex}',file=sys.stderr);return None

def build():
    raw=fetch(); pool=dedupe_and_balance(raw)
    if not pool: raise RuntimeError('No news stories could be retrieved.')
    ai=ai_summarise(pool); output=[]
    if ai:
        for a in ai[:10]:
            try:x=pool[int(a['index'])]
            except Exception:continue
            output.append({'headline':a['headline'],'summary':a['summary'],'category':x['category'],'country':x['country'],'source':x['source'],'published':x['dt'].strftime('%d %b, %H:%M UTC'),'url':x['url'],'confidence':a.get('confidence','Source checked'),'why_it_matters':a.get('why_it_matters','This development may affect regional policy, markets or political risk.')})
    if len(output)<10:
        used={x['url'] for x in output}
        for x in pool:
            if x['url'] in used:continue
            output.append({'headline':re.sub(r'\s+-\s+[^-]{2,50}$','',x['title'])[:110],'summary':fallback_summary(x),'category':x['category'],'country':x['country'],'source':x['source'],'published':x['dt'].strftime('%d %b, %H:%M UTC'),'url':x['url'],'confidence':'Source checked','why_it_matters':f"Monitor for wider implications beyond {x['country']}."})
            if len(output)==10:break
    now=datetime.now(timezone.utc)
    topic_counts=Counter(x['category'] for x in output)
    dominant=topic_counts.most_common(1)[0][0] if topic_counts else 'Mixed'
    country_counts=Counter(x['country'] for x in output if x['country']!='Regional')
    signals=[]
    for name,count in country_counts.most_common(8):
        score=min(100,35+count*22)
        signals.append({'country':name,'score':score,'label':'High attention' if score>=75 else 'Active','reason':f'{count} selected development'+('s' if count!=1 else '')})
    analysis={'title':f'{dominant} leads today’s regional agenda','summary':f'Today’s selected reporting is weighted toward {dominant.lower()} developments. Treat this as an attention signal and verify fast-moving claims through original and official sources.','watch':[f'Follow-up reporting on {x[0]}' for x in country_counts.most_common(3)]}
    prompt={'question':f'How could today’s {dominant.lower()} developments create cross-border effects?','context':'Compare at least two source reports and consider the role of ECOWAS, trade links, migration or security spillovers.'}
    payload={'date':now.date().isoformat(),'display_date':now.strftime('%A, %d %B %Y'),'is_demo':False,'sources_scanned':len({x['source'] for x in raw}),'dominant_theme':dominant,'topic_mix':dict(topic_counts),'country_signals':signals,'analysis':analysis,'study_prompt':prompt,'items':output}
    OUT.parent.mkdir(exist_ok=True);OUT.write_text(json.dumps(payload,ensure_ascii=False,indent=2),encoding='utf-8')
    ARCHIVE.mkdir(parents=True,exist_ok=True);(ARCHIVE/f'{now.date().isoformat()}.json').write_text(json.dumps(payload,ensure_ascii=False,indent=2),encoding='utf-8')
    print(f'Wrote {len(output)} items from {len(raw)} reports to {OUT}')
if __name__=='__main__':build()
